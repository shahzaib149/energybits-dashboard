AIRTABLE_SEO_RUNS_TABLE_ID=your_seo_runs_table_id
AIRTABLE_GA4_PAGE_PERFORMANCE_TABLE_ID=your_ga4_page_performance_table_id
AIRTABLE_GA4_TRAFFIC_SOURCES_TABLE_ID=your_ga4_traffic_sources_table_id
AIRTABLE_GA4_RUNS_TABLE_ID=your_ga4_runs_table_id

# Google Ads Analytics (separate Airtable base — server-side only)
