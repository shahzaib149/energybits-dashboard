# Airtable — single API key; bases and tables are resolved automatically
AIRTABLE_API_KEY=your_airtable_personal_access_token

CAIRROT_API_KEY=your_cairrot_api_key
CAIRROT_API_BASE_URL=https://api.cairrot.com
# From Cairrot: GET /api/v1/projects/list → data.projects[].id (e.g. energybits.com project)
CAIRROT_PROJECT_ID=your_project_id

# Supabase Auth (sign-in page)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Use anon key OR publishable key from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key
# Optional alias (if Supabase gives publishable key name):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# Server-only — for admin invite script, audit log, user management (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Optional — redirect target for magic-link invites (production: https://your-domain.vercel.app)
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
# Optional — real user invite emails for scripts/invite-users.mjs
# INVITE_SHAHZAIB_EMAIL=
# INVITE_CATHARINE_EMAIL=
# INVITE_BRANDON_EMAIL=

# ─── AI Ad Suggestions ────────────────────────────────────────────────────────
# Required to enable the Claude-powered suggestion layer on ad detail views.
# Without this key the feature still works — rules + native platform signals
# are always evaluated; only the AI synthesis layer is skipped.
ANTHROPIC_API_KEY=your_anthropic_api_key

# Model used for ad suggestion synthesis (server-side only).
# Defaults to claude-haiku-4-5-20251001 (fast, low cost per ad view).
# Upgrade to claude-sonnet-4-6 for deeper creative/copy recommendations.
# SUGGESTIONS_AI_MODEL=claude-haiku-4-5-20251001

# ─── Make.com — combined intelligence report → keyword & blog recommendations
MAKE_INTELLIGENCE_WEBHOOK_URL=https://hook.us2.make.com/your_intelligence_webhook_id
# Blog topic submit → AI draft: fired when a user clicks "Submit topic" on Blog Pipeline
BLOG_TRIGGER_WEBHOOK_URL=https://hook.us2.make.com/your_blog_trigger_webhook_id
# Required by Make scenario modules (default: en). Use the exact code your scenario expects.
# MAKE_INTELLIGENCE_LANGUAGE=en
# Make.com — blog publish & content sync webhooks (server-only)
# Publish uses BLOG_SYNC_WEBHOOK_URL when set, otherwise BLOG_PUBLISH_WEBHOOK_URL
BLOG_PUBLISH_WEBHOOK_URL=https://hook.us2.make.com/your_webhook_id
# Optional dedicated hook for preview edits (falls back to BLOG_PUBLISH_WEBHOOK_URL)
# BLOG_SYNC_WEBHOOK_URL=https://hook.us2.make.com/your_sync_webhook_id
