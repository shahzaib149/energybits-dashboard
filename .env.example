AIRTABLE_GOOGLE_ADS_CAMPAIGNS_TABLE_ID=your_campaigns_table_id
AIRTABLE_GOOGLE_ADS_AD_GROUPS_TABLE_ID=your_ad_groups_table_id
AIRTABLE_GOOGLE_ADS_CREATIVES_TABLE_ID=your_creatives_table_id
AIRTABLE_GOOGLE_ADS_KEYWORDS_TABLE_ID=your_keywords_table_id

